<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:MauiSample"
             x:Class="MauiSample.SpeechToTextPage"
             x:DataType="local:SpeechToTextViewModel"
             Title="Speech to Text">
    <ScrollView Padding="20">
        <VerticalStackLayout Spacing="16">

            <!-- Status Card -->
            <Border BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray900}}"
                    Padding="16"
                    StrokeShape="RoundRectangle 12"
                    Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                    StrokeThickness="1">
                <VerticalStackLayout Spacing="4">
                    <Label Text="{Binding StatusText}"
                           FontSize="15"
                           FontFamily="OpenSansSemibold"
                           TextColor="{StaticResource Primary}" />
                    <Label Text="{Binding ConfidenceText}"
                           FontSize="12"
                           TextColor="{StaticResource Gray400}"
                           IsVisible="{Binding HasConfidence}" />
                </VerticalStackLayout>
            </Border>

            <!-- Mode Toggle -->
            <Label Text="MODE"
                   FontSize="11"
                   FontFamily="OpenSansSemibold"
                   TextColor="{StaticResource Gray400}"
                   Margin="0,4,0,0" />
            <Grid ColumnDefinitions="*,*" ColumnSpacing="10" RowDefinitions="Auto,Auto" RowSpacing="10">
                <Button Text="Continuous"
                        Command="{Binding SetModeCommand}"
                        CommandParameter="Continuous"
                        BackgroundColor="{Binding ContinuousButtonColor}"
                        CornerRadius="12" />
                <Button Grid.Column="1"
                        Text="Until Silence"
                        Command="{Binding SetModeCommand}"
                        CommandParameter="UntilSilence"
                        BackgroundColor="{Binding UntilSilenceButtonColor}"
                        CornerRadius="12" />
                <Button Grid.Row="1"
                        Text="Wake Word"
                        Command="{Binding SetModeCommand}"
                        CommandParameter="WakeWord"
                        BackgroundColor="{Binding WakeWordButtonColor}"
                        CornerRadius="12" />
                <Button Grid.Row="1" Grid.Column="1"
                        Text="Keyword"
                        Command="{Binding SetModeCommand}"
                        CommandParameter="Keyword"
                        BackgroundColor="{Binding KeywordButtonColor}"
                        CornerRadius="12" />
            </Grid>

            <!-- Wake Word Settings -->
            <Border BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray900}}"
                    Padding="16"
                    StrokeShape="RoundRectangle 12"
                    Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                    StrokeThickness="1"
                    IsVisible="{Binding IsWakeWordMode}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="WAKE PHRASE"
                           FontSize="11"
                           FontFamily="OpenSansSemibold"
                           TextColor="{StaticResource Gray400}" />
                    <Entry Text="{Binding WakePhrase}"
                           Placeholder="e.g. Hey Computer" />
                </VerticalStackLayout>
            </Border>

            <!-- Keyword Settings -->
            <Border BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray900}}"
                    Padding="16"
                    StrokeShape="RoundRectangle 12"
                    Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                    StrokeThickness="1"
                    IsVisible="{Binding IsKeywordMode}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="KEYWORDS (comma-separated)"
                           FontSize="11"
                           FontFamily="OpenSansSemibold"
                           TextColor="{StaticResource Gray400}" />
                    <Entry Text="{Binding KeywordsText}"
                           Placeholder="e.g. Yes, No, Maybe" />
                </VerticalStackLayout>
            </Border>

            <!-- Settings Card -->
            <Border BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray900}}"
                    Padding="16"
                    StrokeShape="RoundRectangle 12"
                    Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                    StrokeThickness="1">
                <VerticalStackLayout Spacing="12">
                    <Label Text="SETTINGS"
                           FontSize="11"
                           FontFamily="OpenSansSemibold"
                           TextColor="{StaticResource Gray400}" />

                    <Label Text="Language"
                           FontSize="12"
                           TextColor="{StaticResource Gray400}" />
                    <Picker ItemsSource="{Binding AvailableLocales}"
                            ItemDisplayBinding="{Binding DisplayName}"
                            SelectedItem="{Binding SelectedLocale}" />

                    <BoxView HeightRequest="1"
                             Color="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}" />

                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="Prefer On-Device"
                               VerticalOptions="Center" />
                        <Switch Grid.Column="1"
                                IsToggled="{Binding PreferOnDevice}"
                                OnColor="{StaticResource Primary}" />
                    </Grid>

                    <BoxView HeightRequest="1"
                             Color="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}" />

                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="{Binding SilenceTimeoutText}"
                               VerticalOptions="Center" />
                        <Stepper Grid.Column="1"
                                 Minimum="1" Maximum="10" Increment="1"
                                 Value="{Binding SilenceTimeoutSeconds}" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- Controls -->
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                <Button Text="{Binding ListenButtonText}"
                        Command="{Binding ToggleListenCommand}"
                        CornerRadius="12"
                        FontSize="16"
                        HeightRequest="50" />
                <Button Grid.Column="1"
                        Text="Clear"
                        Command="{Binding ClearCommand}"
                        BackgroundColor="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray500}}"
                        CornerRadius="12"
                        HeightRequest="50"
                        WidthRequest="80" />
            </Grid>

            <!-- Recognized Text -->
            <Label Text="RECOGNIZED TEXT"
                   FontSize="11"
                   FontFamily="OpenSansSemibold"
                   TextColor="{StaticResource Gray400}"
                   Margin="0,8,0,0" />
            <Border BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray950}}"
                    Padding="16"
                    StrokeShape="RoundRectangle 12"
                    Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                    StrokeThickness="1"
                    MinimumHeightRequest="200">
                <Label Text="{Binding RecognizedText}"
                       FontSize="16"
                       LineBreakMode="WordWrap" />
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
